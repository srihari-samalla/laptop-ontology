    <!-- http://example.com/laptopontology#BusinessSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#BusinessSmartLaptop">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/laptopontology#SmartLaptop"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Webcam"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


