     -->

    


    <!-- http://example.com/laptopontology#AIEnabledSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#AIEnabledSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Processor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


