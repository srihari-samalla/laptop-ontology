<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.com/laptopontology/"
     xml:base="http://example.com/laptopontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.com/laptopontology">
        <owl:versionIRI rdf:resource="http://example.com/laptopontology/1.0.0"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.com/laptopontology#IsFeatureOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#IsFeatureOf">
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#LaptopMake -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#LaptopMake"/>
    


    <!-- http://example.com/laptopontology#hasCharacteristics -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasCharacteristics">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isCharacteristicsOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#LaptopCharacteristics"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#hasComponent -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasComponent">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isComponentOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#hasFeature -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasFeature"/>
    


    <!-- http://example.com/laptopontology#hasPort -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasPort">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isPortOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#Port"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#hasSecurity -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasSecurity">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#SecuringMechanism"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#hasSensor -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasSensor">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#Sensor"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#isCharacteristicsOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isCharacteristicsOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#IsFeatureOf"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#isComponentOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isComponentOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#IsFeatureOf"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#isPortOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isPortOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#IsFeatureOf"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#isSecurityOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isSecurityOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#IsFeatureOf"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#isSensorOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isSensorOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#IsFeatureOf"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#isrunOSOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isrunOSOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#IsFeatureOf"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#runOS"/>
    </owl:ObjectProperty>
    


    <!-- http://example.com/laptopontology#runOS -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#runOS">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#OperatingSystem"/>
    </owl:ObjectProperty>
    


