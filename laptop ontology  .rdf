        <rdfs:label xml:lang="en">Durability</rdfs:label>
        <rdfs:comment xml:lang="en">A characteristic denoting robust build quality, typically meeting MIL-STD-810 standards for resistance to shock, vibration, dust, and moisture.</rdfs:comment>
    </owl:NamedIndividual>

