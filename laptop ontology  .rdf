<?xml version="1.0"?>
<!--
    Laptop Domain Ontology — Fixed & Enhanced Version
    Version: 2.0.0
    Fixes applied: I-01 through I-15 (see evaluation report)
    Generated by: OWL API compatible RDF/XML
-->
<rdf:RDF xmlns="http://example.com/laptopontology/"
     xml:base="http://example.com/laptopontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#">

    <!-- ===================================================================
         ONTOLOGY HEADER  [FIX I-04: added full metadata]
         =================================================================== -->

    <owl:Ontology rdf:about="http://example.com/laptopontology">
        <owl:versionIRI rdf:resource="http://example.com/laptopontology/2.0.0"/>
        <owl:versionInfo>2.0.0</owl:versionInfo>
        <rdfs:label xml:lang="en">Laptop Domain Ontology</rdfs:label>
        <rdfs:comment xml:lang="en">
            An OWL 2 DL ontology modelling the laptop computing domain,
            covering hardware components, connectivity ports, operating systems,
            security mechanisms, sensors, laptop categories, and manufacturer brands.
        </rdfs:comment>
        <dcterms:description xml:lang="en">
            This ontology provides a formal, machine-readable representation of
            the laptop domain for use in semantic querying, product classification,
            recommender systems, and knowledge graph integration.
        </dcterms:description>
        <dcterms:creator xml:lang="en">Laptop Ontology Project</dcterms:creator>
        <dcterms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-01-01</dcterms:date>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:rights xml:lang="en">This ontology is released under the CC BY 4.0 license.</dcterms:rights>
        <!-- NOTE [I-04]: Replace http://example.com/ with a persistent IRI,
             e.g. https://w3id.org/laptop-ontology, before public release. -->
    </owl:Ontology>



    <!-- =================================================================
         OBJECT PROPERTIES
         ================================================================= -->


    <!-- http://example.com/laptopontology#isFeatureOf
         [FIX I-11: renamed from IsFeatureOf to isFeatureOf (lowercase i)] -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isFeatureOf">
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <rdfs:label xml:lang="en">is feature of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of hasFeature. Relates a feature, component, or characteristic
            to the laptop that possesses it.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#hasFeature -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasFeature">
        <rdfs:label xml:lang="en">has feature</rdfs:label>
        <rdfs:comment xml:lang="en">
            Top-level property relating a laptop to any of its features,
            including components, characteristics, ports, sensors, and security mechanisms.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#hasMake
         [FIX I-01: renamed from LaptopMake (ObjectProperty); added domain, range, inverse] -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasMake">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <!-- [FIX I-14: declared as functional — each laptop has exactly one manufacturer] -->
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isManufacturerOf"/>
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#LaptopMake"/>
        <rdfs:label xml:lang="en">has make</rdfs:label>
        <rdfs:comment xml:lang="en">
            Relates a laptop to its manufacturer (brand). This property is functional:
            a laptop has exactly one manufacturer.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#isManufacturerOf
         [NEW: inverse of hasMake, added as part of I-01 fix] -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isManufacturerOf">
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#hasMake"/>
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#isFeatureOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#LaptopMake"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">is manufacturer of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of hasMake. Relates a manufacturer (brand) to the laptops it produces.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#hasCharacteristics -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasCharacteristics">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isCharacteristicsOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#LaptopCharacteristics"/>
        <rdfs:label xml:lang="en">has characteristics</rdfs:label>
        <rdfs:comment xml:lang="en">
            Relates a laptop to one of its defining characteristics
            (e.g., Portability, Performance, Security, Battery life).
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#isCharacteristicsOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isCharacteristicsOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#isFeatureOf"/>
        <rdfs:label xml:lang="en">is characteristics of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of hasCharacteristics. Relates a characteristic to the laptop
            that exhibits it.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#hasComponent -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasComponent">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isComponentOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">has component</rdfs:label>
        <rdfs:comment xml:lang="en">
            Relates a laptop to a physical hardware component that it contains,
            such as a processor, RAM module, or storage device.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#isComponentOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isComponentOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#isFeatureOf"/>
        <rdfs:label xml:lang="en">is component of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of hasComponent. Relates a hardware component to the laptop
            that contains it.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#hasPort -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasPort">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isPortOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#Port"/>
        <rdfs:label xml:lang="en">has port</rdfs:label>
        <rdfs:comment xml:lang="en">
            Relates a laptop to a connectivity port it exposes,
            such as a USB port, HDMI, or Thunderbolt connector.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#isPortOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isPortOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#isFeatureOf"/>
        <rdfs:label xml:lang="en">is port of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of hasPort. Relates a connectivity port to the laptop
            that exposes it.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#hasSecurity
         [FIX I-07: added explicit owl:inverseOf declaration] -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasSecurity">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isSecurityOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#SecuringMechanism"/>
        <rdfs:label xml:lang="en">has security</rdfs:label>
        <rdfs:comment xml:lang="en">
            Relates a laptop to a security or authentication mechanism it supports,
            such as a fingerprint scanner, face recognition, or TPM chip.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#isSecurityOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isSecurityOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#isFeatureOf"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#hasSecurity"/>
        <rdfs:label xml:lang="en">is security of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of hasSecurity. Relates a security mechanism to the laptop
            it protects.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#hasSensor
         [FIX I-07: added explicit owl:inverseOf declaration] -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#hasSensor">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isSensorOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#Sensor"/>
        <rdfs:label xml:lang="en">has sensor</rdfs:label>
        <rdfs:comment xml:lang="en">
            Relates a laptop to an embedded sensor it contains,
            such as an accelerometer, ambient light sensor, or proximity sensor.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#isSensorOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isSensorOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#isFeatureOf"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#hasSensor"/>
        <rdfs:label xml:lang="en">is sensor of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of hasSensor. Relates a sensor to the laptop that contains it.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#runOS -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#runOS">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#hasFeature"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#isRunOSOf"/>
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://example.com/laptopontology#OperatingSystem"/>
        <rdfs:label xml:lang="en">runs OS</rdfs:label>
        <rdfs:comment xml:lang="en">
            Relates a laptop to the operating system it runs,
            such as Windows, macOS, Linux, or ChromeOS.
        </rdfs:comment>
    </owl:ObjectProperty>


    <!-- http://example.com/laptopontology#isRunOSOf -->

    <owl:ObjectProperty rdf:about="http://example.com/laptopontology#isRunOSOf">
        <rdfs:subPropertyOf rdf:resource="http://example.com/laptopontology#isFeatureOf"/>
        <owl:inverseOf rdf:resource="http://example.com/laptopontology#runOS"/>
        <rdfs:label xml:lang="en">is run OS of</rdfs:label>
        <rdfs:comment xml:lang="en">
            Inverse of runOS. Relates an operating system to the laptops that run it.
        </rdfs:comment>
    </owl:ObjectProperty>



    <!-- =================================================================
         DATA PROPERTIES  [FIX I-08: added full set of data properties]
         ================================================================= -->


    <!-- http://example.com/laptopontology#hasRAMCapacityGB -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasRAMCapacityGB">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#RAM"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">has RAM capacity (GB)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The memory capacity of a RAM module measured in gigabytes (GB).
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasStorageCapacityGB -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasStorageCapacityGB">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Storage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">has storage capacity (GB)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The storage capacity of a storage device measured in gigabytes (GB).
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasDisplaySizeInches -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasDisplaySizeInches">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Display"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has display size (inches)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The diagonal screen size of the laptop display measured in inches.
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasResolutionWidth -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasResolutionWidth">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Display"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">has resolution width (px)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The horizontal pixel count of the display resolution.
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasResolutionHeight -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasResolutionHeight">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Display"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">has resolution height (px)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The vertical pixel count of the display resolution.
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasClockSpeedGHz -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasClockSpeedGHz">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Processor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has clock speed (GHz)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The base clock speed of the processor measured in gigahertz (GHz).
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasWeightKg -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasWeightKg">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has weight (kg)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The physical weight of the laptop measured in kilograms.
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasBatteryLifeHours -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasBatteryLifeHours">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has battery life (hours)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The rated battery life of the laptop under typical usage, measured in hours.
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasBasePriceUSD -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasBasePriceUSD">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has base price (USD)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The manufacturer suggested retail price (MSRP) of the laptop in US dollars.
        </rdfs:comment>
    </owl:DatatypeProperty>


    <!-- http://example.com/laptopontology#hasVRAMCapacityGB -->

    <owl:DatatypeProperty rdf:about="http://example.com/laptopontology#hasVRAMCapacityGB">
        <rdfs:domain rdf:resource="http://example.com/laptopontology#GraphicsCard"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
        <rdfs:label xml:lang="en">has VRAM capacity (GB)</rdfs:label>
        <rdfs:comment xml:lang="en">
            The video memory (VRAM) capacity of the graphics card measured in gigabytes.
        </rdfs:comment>
    </owl:DatatypeProperty>



    <!-- =================================================================
         CLASSES
         ================================================================= -->


    <!-- ── Top-level ─────────────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#ComputingDevice -->

    <owl:Class rdf:about="http://example.com/laptopontology#ComputingDevice">
        <rdfs:label xml:lang="en">Computing Device</rdfs:label>
        <rdfs:comment xml:lang="en">
            An electronic device capable of processing data according to a set of instructions.
            This is the root class of the device taxonomy in this ontology.
        </rdfs:comment>
    </owl:Class>


    <!-- ── Laptop taxonomy ───────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#Laptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#Laptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#ComputingDevice"/>
        <rdfs:label xml:lang="en">Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A portable personal computing device with an integrated screen, keyboard,
            and battery. Direct subclass of ComputingDevice.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#BudgetLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#BudgetLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">Budget Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            An entry-level laptop designed for affordability, typically priced below $500 USD,
            offering basic computing capabilities for everyday tasks.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#BusinessLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#BusinessLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">Business Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A laptop designed for professional and enterprise use, typically featuring
            enhanced security, durability, and manageability features.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#ConvertibleLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#ConvertibleLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">Convertible Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A laptop with a 360-degree hinge or detachable screen that allows it to
            function as both a traditional laptop and a tablet.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#GamingLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#GamingLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">Gaming Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A high-performance laptop optimised for video gaming, featuring dedicated
            graphics cards, high-refresh-rate displays, and advanced cooling systems.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#StudentLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#StudentLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">Student Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A laptop tailored for academic use, balancing affordability, portability,
            and battery life for classroom and study environments.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Ultrabook -->

    <owl:Class rdf:about="http://example.com/laptopontology#Ultrabook">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">Ultrabook</rdfs:label>
        <rdfs:comment xml:lang="en">
            A thin and lightweight laptop conforming to Intel Ultrabook specifications,
            characterised by fast SSD storage, long battery life, and slim form factor.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#WorkstationLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#WorkstationLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:label xml:lang="en">Workstation Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A professional-grade laptop with high computational power, designed for
            demanding workloads such as 3D rendering, CAD, simulation, and data science.
        </rdfs:comment>
    </owl:Class>


    <!-- ── SmartLaptop branch ────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#SmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#SmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Laptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Display"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Keyboard"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            An advanced laptop that must have at minimum a display and a keyboard component,
            serving as the parent class for all specialised smart laptop variants such as
            gaming, business, developer, and AI-enabled models.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#AIEnabledSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#AIEnabledSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Processor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#GraphicsCard"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">AI-Enabled Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop equipped with a dedicated AI-accelerated processor and graphics card,
            capable of running on-device machine learning and neural network inference workloads.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#BusinessSmartLaptop
         [FIX I-06: strengthened equivalentClass — now requires Webcam + TPMChip + Security characteristic] -->

    <owl:Class rdf:about="http://example.com/laptopontology#BusinessSmartLaptop">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/laptopontology#SmartLaptop"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Webcam"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasSecurity"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#TPMChip"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasCharacteristics"/>
                        <owl:hasValue rdf:resource="http://example.com/laptopontology#Security"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="en">Business Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop designed for corporate use: must have a webcam, a TPM security
            chip, and the Security characteristic. Equivalent to the intersection of
            SmartLaptop, hasComponent some Webcam, hasSecurity some TPMChip, and
            hasCharacteristics value Security.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#DeveloperSmartLaptop
         [FIX I-05: strengthened equivalentClass — now requires Processor + Performance characteristic,
          removing the vacuous "hasComponent some RAM" condition] -->

    <owl:Class rdf:about="http://example.com/laptopontology#DeveloperSmartLaptop">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/laptopontology#SmartLaptop"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Processor"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                        <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Storage"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasCharacteristics"/>
                        <owl:hasValue rdf:resource="http://example.com/laptopontology#Performance"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="en">Developer Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop optimised for software development: must have a high-performance
            processor, storage, and the Performance characteristic. Equivalent to the
            intersection of SmartLaptop, hasComponent some Processor,
            hasComponent some Storage, and hasCharacteristics value Performance.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#GamingSmartLaptop
         [FIX I-13: added owl:Restriction — must have a GraphicsCard component] -->

    <owl:Class rdf:about="http://example.com/laptopontology#GamingSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#GraphicsCard"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#CoolingFan"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Gaming Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop built for gaming: must include a dedicated graphics card
            and a cooling fan. Targets high-frame-rate gaming at 1080p or above.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#LightweightSmartLaptop
         [FIX I-13: added owl:Restriction — must have Portability characteristic] -->

    <owl:Class rdf:about="http://example.com/laptopontology#LightweightSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasCharacteristics"/>
                <owl:hasValue rdf:resource="http://example.com/laptopontology#Portability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Lightweight Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop characterised by low weight and high portability,
            designed for users who prioritise mobility over raw performance.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#MedicalUseSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#MedicalUseSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Storage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Medical Use Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop engineered for healthcare environments, requiring high-capacity
            storage for medical records and imaging data, and typically meeting clinical
            hygiene and reliability standards.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#MultiPurposeSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#MultiPurposeSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasComponent"/>
                <owl:someValuesFrom rdf:resource="http://example.com/laptopontology#Motherboard"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Multi-Purpose Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A versatile smart laptop suitable for a broad range of tasks including
            productivity, light gaming, content creation, and communication.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#PerformanceSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#PerformanceSmartLaptop">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.com/laptopontology#SmartLaptop"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.com/laptopontology#hasCharacteristics"/>
                        <owl:hasValue rdf:resource="http://example.com/laptopontology#Performance"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:label xml:lang="en">Performance Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop whose defining characteristic is high performance. Equivalent to
            any SmartLaptop that hasCharacteristics value Performance.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#SlimSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#SlimSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasCharacteristics"/>
                <owl:hasValue rdf:resource="http://example.com/laptopontology#Portability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Slim Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop with a slim profile and the Portability characteristic,
            typically less than 15mm thick and under 1.5kg in weight.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#SpecialistSmartLaptop -->

    <owl:Class rdf:about="http://example.com/laptopontology#SpecialistSmartLaptop">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SmartLaptop"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.com/laptopontology#hasCharacteristics"/>
                <owl:hasValue rdf:resource="http://example.com/laptopontology#Security"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Specialist Smart Laptop</rdfs:label>
        <rdfs:comment xml:lang="en">
            A smart laptop built for specialist professional use cases (e.g., military,
            government, or critical infrastructure), characterised by advanced security features.
        </rdfs:comment>
    </owl:Class>


    <!-- ── Hardware Components ────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#LaptopComponents -->

    <owl:Class rdf:about="http://example.com/laptopontology#LaptopComponents">
        <rdfs:label xml:lang="en">Laptop Components</rdfs:label>
        <rdfs:comment xml:lang="en">
            The class of all physical hardware components that can be contained within
            or attached to a laptop. Serves as the parent class for all component subclasses.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Processor -->

    <owl:Class rdf:about="http://example.com/laptopontology#Processor">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Processor</rdfs:label>
        <rdfs:comment xml:lang="en">
            The central processing unit (CPU) of the laptop, responsible for executing
            program instructions. Examples: Intel Core i7, AMD Ryzen 9.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#RAM -->

    <owl:Class rdf:about="http://example.com/laptopontology#RAM">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">RAM</rdfs:label>
        <rdfs:comment xml:lang="en">
            Random Access Memory — the volatile working memory used by the processor
            to store data and machine code currently in use.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Storage -->

    <owl:Class rdf:about="http://example.com/laptopontology#Storage">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Storage</rdfs:label>
        <rdfs:comment xml:lang="en">
            Non-volatile data storage in a laptop, including solid-state drives (SSD)
            and hard disk drives (HDD).
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Display -->

    <owl:Class rdf:about="http://example.com/laptopontology#Display">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Display</rdfs:label>
        <rdfs:comment xml:lang="en">
            The integrated screen of the laptop, typically an LCD, OLED, or IPS panel,
            characterised by size (inches) and resolution (pixels).
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Keyboard -->

    <owl:Class rdf:about="http://example.com/laptopontology#Keyboard">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Keyboard</rdfs:label>
        <rdfs:comment xml:lang="en">
            The built-in alphanumeric input device of a laptop, used for text entry
            and command input.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Touchpad -->

    <owl:Class rdf:about="http://example.com/laptopontology#Touchpad">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Touchpad</rdfs:label>
        <rdfs:comment xml:lang="en">
            The built-in pointing device on a laptop, used for cursor control and
            gesture-based input in lieu of an external mouse.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Webcam -->

    <owl:Class rdf:about="http://example.com/laptopontology#Webcam">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Webcam</rdfs:label>
        <rdfs:comment xml:lang="en">
            An integrated or attachable video camera used for video conferencing,
            streaming, and image capture.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Motherboard -->

    <owl:Class rdf:about="http://example.com/laptopontology#Motherboard">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Motherboard</rdfs:label>
        <rdfs:comment xml:lang="en">
            The main printed circuit board (PCB) of the laptop that interconnects
            all major components including CPU, RAM, storage, and peripheral controllers.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#CoolingFan -->

    <owl:Class rdf:about="http://example.com/laptopontology#CoolingFan">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Cooling Fan</rdfs:label>
        <rdfs:comment xml:lang="en">
            An active thermal management component that dissipates heat generated by
            the CPU and GPU to prevent thermal throttling.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#GraphicsCard
         [NEW: I-09 fix — dedicated GPU component] -->

    <owl:Class rdf:about="http://example.com/laptopontology#GraphicsCard">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Graphics Card</rdfs:label>
        <rdfs:comment xml:lang="en">
            A dedicated graphics processing unit (GPU) responsible for rendering images,
            video, and 3D graphics. Distinct from integrated graphics embedded in the CPU.
            Examples: NVIDIA GeForce RTX, AMD Radeon RX.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Battery
         [NEW: I-09 fix — Battery as a physical component class;
          the LaptopCharacteristics individual has been renamed to BatteryLife to avoid punning] -->

    <owl:Class rdf:about="http://example.com/laptopontology#Battery">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Battery</rdfs:label>
        <rdfs:comment xml:lang="en">
            The rechargeable lithium-ion or lithium-polymer power cell that provides
            portable power to the laptop.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#WiFiAdapter
         [NEW: I-09 fix] -->

    <owl:Class rdf:about="http://example.com/laptopontology#WiFiAdapter">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Wi-Fi Adapter</rdfs:label>
        <rdfs:comment xml:lang="en">
            A wireless networking component that enables the laptop to connect to
            IEEE 802.11 (Wi-Fi) networks. May support standards such as Wi-Fi 6 (802.11ax).
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#BluetoothModule
         [NEW: I-09 fix] -->

    <owl:Class rdf:about="http://example.com/laptopontology#BluetoothModule">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Bluetooth Module</rdfs:label>
        <rdfs:comment xml:lang="en">
            A short-range wireless communication component enabling the laptop to
            connect to Bluetooth peripherals such as headphones, mice, and keyboards.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Speaker
         [NEW: I-09 fix] -->

    <owl:Class rdf:about="http://example.com/laptopontology#Speaker">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Speaker</rdfs:label>
        <rdfs:comment xml:lang="en">
            An integrated audio output transducer in the laptop for reproducing sound.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Microphone
         [NEW: I-09 fix] -->

    <owl:Class rdf:about="http://example.com/laptopontology#Microphone">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#LaptopComponents"/>
        <rdfs:label xml:lang="en">Microphone</rdfs:label>
        <rdfs:comment xml:lang="en">
            An integrated audio input transducer in the laptop for capturing voice
            and ambient sound, used in video calls, voice recognition, and recording.
        </rdfs:comment>
    </owl:Class>


    <!-- ── Connectivity Ports ─────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#Port -->

    <owl:Class rdf:about="http://example.com/laptopontology#Port">
        <rdfs:label xml:lang="en">Port</rdfs:label>
        <rdfs:comment xml:lang="en">
            A physical connector on the laptop chassis that allows connection to
            external devices or networks. Parent class of all specific port types.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#USBPort -->

    <owl:Class rdf:about="http://example.com/laptopontology#USBPort">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Port"/>
        <rdfs:label xml:lang="en">USB Port</rdfs:label>
        <rdfs:comment xml:lang="en">
            A Universal Serial Bus connector for attaching peripherals and transferring
            data. Parent class for USB-A and USB-C variants.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#USB_A -->

    <owl:Class rdf:about="http://example.com/laptopontology#USB_A">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#USBPort"/>
        <owl:disjointWith rdf:resource="http://example.com/laptopontology#USB_C"/>
        <rdfs:label xml:lang="en">USB-A Port</rdfs:label>
        <rdfs:comment xml:lang="en">
            The rectangular USB Type-A connector, the most widely used USB form factor,
            supporting USB 2.0, 3.0, and 3.1 standards.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#USB_C -->

    <owl:Class rdf:about="http://example.com/laptopontology#USB_C">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#USBPort"/>
        <rdfs:label xml:lang="en">USB-C Port</rdfs:label>
        <rdfs:comment xml:lang="en">
            The oval USB Type-C connector supporting USB 3.1/3.2, USB4, and often
            Thunderbolt 3/4. Reversible and capable of Power Delivery (PD) charging.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#HDMI -->

    <owl:Class rdf:about="http://example.com/laptopontology#HDMI">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Port"/>
        <rdfs:label xml:lang="en">HDMI Port</rdfs:label>
        <rdfs:comment xml:lang="en">
            High-Definition Multimedia Interface — a digital audio/video interface
            for connecting the laptop to external monitors, TVs, and projectors.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Thunderbolt -->

    <owl:Class rdf:about="http://example.com/laptopontology#Thunderbolt">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Port"/>
        <rdfs:label xml:lang="en">Thunderbolt Port</rdfs:label>
        <rdfs:comment xml:lang="en">
            Intel Thunderbolt interface (versions 3/4) offering high-speed data transfer
            (up to 40 Gbps), video output, and Power Delivery over a USB-C connector.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#AudioJack -->

    <owl:Class rdf:about="http://example.com/laptopontology#AudioJack">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Port"/>
        <rdfs:label xml:lang="en">Audio Jack</rdfs:label>
        <rdfs:comment xml:lang="en">
            A 3.5mm TRS/TRRS analogue audio connector for connecting headphones,
            earphones, or external microphones.
        </rdfs:comment>
    </owl:Class>


    <!-- ── Operating Systems ─────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#OperatingSystem -->

    <owl:Class rdf:about="http://example.com/laptopontology#OperatingSystem">
        <rdfs:label xml:lang="en">Operating System</rdfs:label>
        <rdfs:comment xml:lang="en">
            System software that manages hardware resources and provides services for
            application software. Parent class for all OS subclasses in this ontology.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#WindowsOS -->

    <owl:Class rdf:about="http://example.com/laptopontology#WindowsOS">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#OperatingSystem"/>
        <rdfs:label xml:lang="en">Windows OS</rdfs:label>
        <rdfs:comment xml:lang="en">
            Microsoft Windows operating system family (e.g., Windows 10, Windows 11),
            the most widely used OS for consumer and business laptops.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#MacOS -->

    <owl:Class rdf:about="http://example.com/laptopontology#MacOS">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#OperatingSystem"/>
        <rdfs:label xml:lang="en">macOS</rdfs:label>
        <rdfs:comment xml:lang="en">
            Apple macOS (formerly OS X), the Unix-based operating system exclusively
            used on Apple MacBook laptop models.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#LinuxOS -->

    <owl:Class rdf:about="http://example.com/laptopontology#LinuxOS">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#OperatingSystem"/>
        <rdfs:label xml:lang="en">Linux OS</rdfs:label>
        <rdfs:comment xml:lang="en">
            The Linux kernel-based family of open-source operating systems
            (e.g., Ubuntu, Fedora, Debian) commonly used on developer and workstation laptops.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#ChromeOS
         [NEW: I-12 fix] -->

    <owl:Class rdf:about="http://example.com/laptopontology#ChromeOS">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#OperatingSystem"/>
        <rdfs:label xml:lang="en">ChromeOS</rdfs:label>
        <rdfs:comment xml:lang="en">
            Google ChromeOS, a Linux-based operating system designed primarily for
            web-based applications, used exclusively on Chromebook laptops.
            Widely deployed in the K-12 education sector.
        </rdfs:comment>
    </owl:Class>


    <!-- ── Security Mechanisms ───────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#SecuringMechanism -->

    <owl:Class rdf:about="http://example.com/laptopontology#SecuringMechanism">
        <rdfs:label xml:lang="en">Securing Mechanism</rdfs:label>
        <rdfs:comment xml:lang="en">
            A hardware or software mechanism that provides security, authentication,
            or physical protection for the laptop and its data.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#FingerprintScanner -->

    <owl:Class rdf:about="http://example.com/laptopontology#FingerprintScanner">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SecuringMechanism"/>
        <rdfs:label xml:lang="en">Fingerprint Scanner</rdfs:label>
        <rdfs:comment xml:lang="en">
            A biometric sensor that reads and authenticates users by their fingerprint,
            typically embedded in the power button or palm rest.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#FaceRecognition -->

    <owl:Class rdf:about="http://example.com/laptopontology#FaceRecognition">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SecuringMechanism"/>
        <rdfs:label xml:lang="en">Face Recognition</rdfs:label>
        <rdfs:comment xml:lang="en">
            A biometric authentication mechanism that uses an IR or depth camera to
            identify and authenticate the user by facial features (e.g., Windows Hello).
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#BIOSPassword -->

    <owl:Class rdf:about="http://example.com/laptopontology#BIOSPassword">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SecuringMechanism"/>
        <rdfs:label xml:lang="en">BIOS Password</rdfs:label>
        <rdfs:comment xml:lang="en">
            A firmware-level password set in the BIOS/UEFI that restricts unauthorised
            booting or configuration changes before the OS loads.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#KensingtonLock -->

    <owl:Class rdf:about="http://example.com/laptopontology#KensingtonLock">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SecuringMechanism"/>
        <rdfs:label xml:lang="en">Kensington Lock</rdfs:label>
        <rdfs:comment xml:lang="en">
            A physical anti-theft mechanism: a reinforced slot on the laptop chassis
            into which a Kensington-compatible lock and cable can be attached to
            secure the device to a fixed object.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#TPMChip -->

    <owl:Class rdf:about="http://example.com/laptopontology#TPMChip">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#SecuringMechanism"/>
        <rdfs:label xml:lang="en">TPM Chip</rdfs:label>
        <rdfs:comment xml:lang="en">
            Trusted Platform Module — a dedicated microcontroller that stores
            cryptographic keys, certificates, and passwords, enabling hardware-based
            security for full-disk encryption (e.g., BitLocker) and secure boot.
        </rdfs:comment>
    </owl:Class>


    <!-- ── Sensors ───────────────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#Sensor -->

    <owl:Class rdf:about="http://example.com/laptopontology#Sensor">
        <rdfs:label xml:lang="en">Sensor</rdfs:label>
        <rdfs:comment xml:lang="en">
            An embedded transducer that detects and measures physical or environmental
            conditions and reports them to the laptop's operating system or applications.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#Accelerometer -->

    <owl:Class rdf:about="http://example.com/laptopontology#Accelerometer">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Sensor"/>
        <rdfs:label xml:lang="en">Accelerometer</rdfs:label>
        <rdfs:comment xml:lang="en">
            A sensor that measures proper acceleration and orientation changes,
            used for screen auto-rotation, free-fall detection, and hard-drive protection.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#AmbientLightSensor -->

    <owl:Class rdf:about="http://example.com/laptopontology#AmbientLightSensor">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Sensor"/>
        <rdfs:label xml:lang="en">Ambient Light Sensor</rdfs:label>
        <rdfs:comment xml:lang="en">
            A photosensor that measures surrounding light levels to automatically
            adjust display brightness for power efficiency and user comfort.
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#ProximitySensor -->

    <owl:Class rdf:about="http://example.com/laptopontology#ProximitySensor">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Sensor"/>
        <rdfs:label xml:lang="en">Proximity Sensor</rdfs:label>
        <rdfs:comment xml:lang="en">
            A sensor that detects the presence or absence of a user near the laptop,
            enabling automatic wake/sleep behaviour (e.g., Intel Wake-on-Approach).
        </rdfs:comment>
    </owl:Class>


    <!-- http://example.com/laptopontology#TemperatureSensor -->

    <owl:Class rdf:about="http://example.com/laptopontology#TemperatureSensor">
        <rdfs:subClassOf rdf:resource="http://example.com/laptopontology#Sensor"/>
        <rdfs:label xml:lang="en">Temperature Sensor</rdfs:label>
        <rdfs:comment xml:lang="en">
            A thermal sensor that monitors internal component temperatures (CPU, GPU,
            battery) and triggers cooling responses or throttling to prevent overheating.
        </rdfs:comment>
    </owl:Class>


    <!-- ── LaptopMake (class) ─────────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#LaptopMake
         [NOTE I-01: This is ONLY the class. The old ObjectProperty named LaptopMake
          has been removed and replaced by the hasMake property above.] -->

    <owl:Class rdf:about="http://example.com/laptopontology#LaptopMake">
        <rdfs:label xml:lang="en">Laptop Make</rdfs:label>
        <rdfs:comment xml:lang="en">
            The manufacturer or brand that produces a laptop. Instances of this class
            represent specific brands such as Dell, HP, Apple, and Lenovo.
        </rdfs:comment>
    </owl:Class>


    <!-- ── LaptopCharacteristics ─────────────────────────────────────── -->


    <!-- http://example.com/laptopontology#LaptopCharacteristics -->

    <owl:Class rdf:about="http://example.com/laptopontology#LaptopCharacteristics">
        <rdfs:label xml:lang="en">Laptop Characteristics</rdfs:label>
        <rdfs:comment xml:lang="en">
            An abstract quality or defining trait of a laptop that describes its
            overall profile, such as performance level, portability, durability, or security.
        </rdfs:comment>
    </owl:Class>



